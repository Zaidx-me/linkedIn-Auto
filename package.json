{
  "name": "linkedin-content-gen",
  "version": "1.0.0",
  "description": "NVIDIA NIM-powered LinkedIn content generation service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "generate:cli": "tsx src/cli.ts",
    "start": "npm run build && node dist/server.js",
    "start:dev": "tsx src/server.ts",
    "start:quick": "node dist/server.js",
    "auth:login": "tsx src/auth/login.ts",
    "schedule": "tsx src/scheduler/scheduler.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "playwright": "^1.48.0",
    "sql.js": "^1.14.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.15",
    "@types/sql.js": "^1.4.11",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
